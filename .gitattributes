# Normalize line endings: LF in the repo, checked out native on each platform.
* text=auto eol=lf

# Treat Go and common text files as text explicitly.
*.go    text eol=lf
*.md    text eol=lf
*.yaml  text eol=lf
*.yml   text eol=lf
*.json  text eol=lf

# Binary assets, if any are ever added.
*.png   binary
*.jpg   binary
*.gif   binary
